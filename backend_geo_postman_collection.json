{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcde00",
		"name": "Backend Geo Location API",
		"description": "API collection for the Mini Spatial Data Platform (backend-geo) which allows performing CRUD operations on GeoJSON location features.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/health",
					"host": [
						"{{base_url}}"
					],
					"path": [
						"api",
						"health"
					]
				},
				"description": "Returns the health status of the API server."
			},
			"response": []
		},
		{
			"name": "Locations",
			"description": "Endpoints for managing location features in GeoJSON format.",
			"item": [
				{
					"name": "Get All Locations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/locations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"locations"
							]
						},
						"description": "Fetch all recorded location features from the database."
					},
					"response": []
				},
				{
					"name": "Create Location",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if(jsonData.id) {",
									"    pm.collectionVariables.set(\"location_id\", jsonData.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"Feature\",\n    \"geometry\": {\n        \"type\": \"Point\",\n        \"coordinates\": [100.5018, 13.7563]\n    },\n    \"properties\": {\n        \"name\": \"Bangkok\",\n        \"description\": \"Capital city of Thailand\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/locations",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"locations"
							]
						},
						"description": "Create a new location feature."
					},
					"response": []
				},
				{
					"name": "Update Location",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"type\": \"Feature\",\n    \"geometry\": {\n        \"type\": \"Point\",\n        \"coordinates\": [100.5018, 13.7563]\n    },\n    \"properties\": {\n        \"name\": \"Bangkok - Updated\",\n        \"description\": \"Updated description for Bangkok\"\n    }\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/locations/{{location_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"locations",
								"{{location_id}}"
							]
						},
						"description": "Update an existing location feature. Ensure `location_id` variable is set."
					},
					"response": []
				},
				{
					"name": "Delete Location",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/locations/{{location_id}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"locations",
								"{{location_id}}"
							]
						},
						"description": "Delete a location feature by ID."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "location_id",
			"value": "",
			"type": "string"
		}
	]
}
